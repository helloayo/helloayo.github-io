---

<Page title="Writing — Ayo Suber" section="Writing">

  <div class="writing-header">
    <h1 class="page-title">Writing</h1>
    <div class="view-toggle">
      <button class="toggle-btn active" id="btn-list" aria-label="List view">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="0" y="2"  width="16" height="1.5" rx="0.75" fill="currentColor"/>
          <rect x="0" y="7"  width="16" height="1.5" rx="0.75" fill="currentColor"/>
          <rect x="0" y="12" width="16" height="1.5" rx="0.75" fill="currentColor"/>
        </svg>
        List
      </button>
      <button class="toggle-btn" id="btn-grid" aria-label="Grid view">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <rect x="0" y="0" width="7" height="7" rx="1" fill="currentColor"/>
          <rect x="9" y="0" width="7" height="7" rx="1" fill="currentColor"/>
          <rect x="0" y="9" width="7" height="7" rx="1" fill="currentColor"/>
          <rect x="9" y="9" width="7" height="7" rx="1" fill="currentColor"/>
        </svg>
        Grid
      </button>
    </div>
  </div>

  <p class="writing-intro">
    Reporting for <a href="https://hoodline.com" target="_blank" rel="noopener" class="hoodline-link">Hoodline</a>
    — the go-to source for news about the places San Franciscans live, work, and play.
  </p>

  <!-- LIST VIEW -->
  <ul class="writing-list" id="view-list">
    {pieces.map((p) => (
      <li class="writing-item">
        <a href={p.href} target="_blank" rel="noopener" class="writing-link">
          <span class="writing-tag">{p.tag}</span>
          <span class="writing-title">{p.title}</span>
          <span class="writing-pub">{p.publication}</span>
          <span class="writing-year">{p.year}</span>
          <span class="writing-arrow">↗</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- GRID VIEW -->
  <div class="writing-grid" id="view-grid">
    {pieces.map((p) => (
      <a href={p.href} target="_blank" rel="noopener" class="writing-card">
        <div class="card-image">
          <img src={p.image} alt={p.title} loading="lazy" />
          <span class="card-tag">{p.tag}</span>
        </div>
        <div class="card-body">
          <p class="card-title">{p.title}</p>
          <span class="card-meta">{p.publication} · {p.year}</span>
        </div>
      </a>
    ))}
  </div>

</Page>

<style>
  /* ---- HEADER ROW ---- */
  .writing-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 20px;
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--white);
  }

  /* ---- TOGGLE ---- */
  .view-toggle {
    display: flex;
    gap: 2px;
    border: 1px solid #1a1a1a;
    padding: 3px;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted);
    background: none;
    border: none;
    padding: 7px 14px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .toggle-btn:hover { color: var(--white); }

  .toggle-btn.active {
    background: #1a1a1a;
    color: var(--white);
  }

  /* ---- INTRO ---- */
  .writing-intro {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.03em;
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .hoodline-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---- LIST VIEW ---- */
  .writing-list {
    list-style: none;
    border-top: 1px solid #1a1a1a;
  }

  .writing-item { border-bottom: 1px solid #1a1a1a; }

  .writing-link {
    display: grid;
    grid-template-columns: 72px 1fr auto auto 24px;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
    transition: padding 0.15s, background 0.15s;
  }

  .writing-link:hover {
    padding-left: 12px;
    padding-right: 12px;
    margin: 0 -12px;
    background: #111;
  }

  .writing-link:hover .writing-title { color: var(--accent); }

  .writing-link:hover .writing-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .writing-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .writing-title {
    font-family: var(--serif);
    font-size: 20px;
    color: var(--white);
    transition: color 0.15s;
  }

  .writing-pub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.04em;
    text-align: right;
  }

  .writing-year {
    font-family: var(--mono);
    font-size: 11px;
    color: #2a2a2a;
    letter-spacing: 0.04em;
    min-width: 36px;
    text-align: right;
  }

  .writing-arrow {
    font-size: 14px;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  /* ---- GRID VIEW ---- */
  .writing-grid {
    display: none;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .writing-card {
    display: flex;
    flex-direction: column;
    background: #111;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.2s;
  }

  .writing-card:hover { background: #161616; }
  .writing-card:hover .card-image img { transform: scale(1.03); }
  .writing-card:hover .card-title { color: var(--accent); }

  .card-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    filter: grayscale(20%);
  }

  .card-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--accent);
    padding: 3px 8px;
  }

  .card-body {
    padding: 20px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .card-title {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.35;
    color: var(--white);
    transition: color 0.2s;
  }

  .card-meta {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: auto;
  }

  /* active grid state — toggled by JS */
  .writing-grid.active {
    display: grid;
  }

  .writing-list.hidden {
    display: none;
  }

  @media (max-width: 700px) {
    .writing-grid { grid-template-columns: 1fr; }
    .writing-link {
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto;
      row-gap: 6px;
      column-gap: 12px;
    }
    .writing-pub  { display: none; }
    .writing-arrow { display: none; }
    .writing-year { text-align: right; }
  }
</style>

<script>
  const btnList = document.getElementById('btn-list');
  const btnGrid = document.getElementById('btn-grid');
  const viewList = document.getElementById('view-list');
  const viewGrid = document.getElementById('view-grid');

  btnList.addEventListener('click', () => {
    btnList.classList.add('active');
    btnGrid.classList.remove('active');
    viewList.classList.remove('hidden');
    viewGrid.classList.remove('active');
  });

  btnGrid.addEventListener('click', () => {
    btnGrid.classList.add('active');
    btnList.classList.remove('active');
    viewGrid.classList.add('active');
    viewList.classList.add('hidden');
  });
</script>